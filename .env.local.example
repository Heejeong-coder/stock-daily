# =============================================
# .env.local — 로컬 개발용 환경변수
# Vercel 배포 시 Vercel Dashboard > Settings > Environment Variables에 동일하게 입력
# =============================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-여기에_API키_입력

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://여기에_프로젝트ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_anon_key_입력
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_key_입력

# Cron 보안 시크릿 (임의 문자열로 설정, 예: openssl rand -hex 32)
CRON_SECRET=여기에_임의_시크릿_문자열_입력

# 앱 URL (Vercel 배포 후 실제 URL로 변경)
NEXT_PUBLIC_APP_URL=http://localhost:3000
